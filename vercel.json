{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/oauth/:path*",
      "destination": "http://187.77.182.159:3099/api/oauth/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/agent-tick",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/ml-train",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-stale-pending",
      "schedule": "30 4 * * *"
    }
  ]
}
