# Database
DATABASE_URL="postgresql://user:password@localhost:5432/projectoolbox"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# AI
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Email
RESEND_API_KEY=""

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Enterprise SAML SSO (WorkOS) — leave unset to disable SSO
# Get keys from https://dashboard.workos.com → Project → API Keys
# Configure the WorkOS Project's redirect URI to: ${NEXTAUTH_URL}/api/auth/workos/callback
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""

# Sentry (error monitoring) — leave unset to run without Sentry
# Server + edge runtime use SENTRY_DSN; the browser bundle uses NEXT_PUBLIC_SENTRY_DSN
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed at BUILD time (CI / Vercel) to upload source maps + tag releases
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""