generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth adapter) ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Orgs ───

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  emailVerified      DateTime?
  name               String?
  passwordHash       String?
  image              String?
  role               UserRole        @default(MEMBER)
  onboardingComplete Boolean         @default(false)
  notificationPrefs  Json?
  orgId              String?
  org                Organisation?   @relation(fields: [orgId], references: [id])
  accounts           Account[]
  sessions           Session[]
  projects           ProjectMember[]
  approvals          Approval[]
  notifications      Notification[]
  decisions          Decision[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Organisation {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  industry         String?
  companySize      String?
  website          String?
  timezone         String              @default("Europe/London")
  billingEmail     String?
  plan             PlanTier            @default(FREE)
  stripeCustomerId String?             @unique
  stripeSubId      String?
  creditBalance    Int                 @default(0)
  autoTopUp        Json?
  users            User[]
  projects         Project[]
  agents           Agent[]
  invoices         Invoice[]
  creditTxns       CreditTransaction[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  reports          Report[]
  dailyDigests     DailyDigest[]
  meetings         Meeting[]
  calendarEvents   CalendarEvent[]
  agentInbox       AgentInboxMessage[]
  globalHitlPolicy Json?               // org-level HITL governance overrides
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

// ─── Projects ───

model Project {
  id             String            @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus     @default(ACTIVE)
  methodology    Methodology       @default(WATERFALL)
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  priority       String?
  category       String?
  orgId          String
  org            Organisation      @relation(fields: [orgId], references: [id])
  members        ProjectMember[]
  agents         AgentDeployment[]
  phases         Phase[]
  tasks          Task[]
  risks          Risk[]
  issues         Issue[]
  changeRequests ChangeRequest[]
  stakeholders   Stakeholder[]
  approvals      Approval[]
  reports        Report[]
  meetings       Meeting[]
  calendarEvents CalendarEvent[]
  decisions      Decision[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ProjectMember {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  role      String  @default("MEMBER")

  @@unique([userId, projectId])
}

// ─── Agents ───

model Agent {
  id               String            @id @default(cuid())
  name             String
  codename         String
  title            String?           // user-defined job title e.g. "CRM Migration Lead"
  status           AgentStatus       @default(IDLE)
  autonomyLevel    Int               @default(2)
  personality      Json?
  gradient         String?
  avatarUrl        String?           // custom avatar image URL
  defaultGreeting  String?           // first-activation greeting
  domainTags       String[]          @default([]) // specialism tags e.g. ["PRINCE2", "Agile"]
  monthlyBudget    Int?              // credit cap per calendar month
  orgId            String
  org              Organisation      @relation(fields: [orgId], references: [id])
  deployments      AgentDeployment[]
  decisions        AgentDecision[]
  activities       AgentActivity[]
  chatMessages     ChatMessage[]
  meetings         Meeting[]
  calendarEvents   CalendarEvent[]
  agentEmail       AgentEmail?
  inboxMessages    AgentInboxMessage[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  decommissionedAt DateTime?
}

model AgentDeployment {
  id             String    @id @default(cuid())
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id])
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  isActive       Boolean   @default(true)
  config         Json?
  deployedAt     DateTime  @default(now())
  // Autonomous lifecycle state
  currentPhase   String?
  phaseStatus    String?   @default("active") // active | pending_approval | completed
  lastCycleAt    DateTime?
  nextCycleAt    DateTime?
  cycleInterval  Int       @default(10) // minutes between autonomous cycles
  healthStatus   String?   @default("GREEN") // GREEN | AMBER | RED
  autonomyConfig Json?     // { budgetApprovalThreshold, scopeChangeLimit, autoApprovePhases, requireApprovalFor }
  // HITL governance overrides (explicit columns for queryability)
  hitlPhaseGates      Boolean  @default(true)   // phase gates always require approval
  hitlBudgetChanges   Boolean  @default(true)   // budget changes always require approval
  hitlCommunications  Boolean  @default(false)  // external comms require approval
  escalationTimeout   Int      @default(24)     // hours before approval escalation
}

model AgentDecision {
  id          String         @id @default(cuid())
  agentId     String
  agent       Agent          @relation(fields: [agentId], references: [id])
  type        DecisionType
  description String
  reasoning   String         @db.Text
  confidence  Float
  status      DecisionStatus @default(PENDING)
  approvalId  String?        @unique
  approval    Approval?      @relation(fields: [approvalId], references: [id])
  createdAt   DateTime       @default(now())
}

model AgentActivity {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String
  summary   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id])
  conversationId String?
  role           String
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())
}

// ─── Approvals (HITL) ───

model Approval {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  requestedById String
  assignedToId  String?
  assignedTo    User?          @relation(fields: [assignedToId], references: [id])
  type          ApprovalType
  title         String
  description   String         @db.Text
  impact        Json?
  status        ApprovalStatus @default(PENDING)
  decision      AgentDecision?
  comment       String?        @db.Text
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  // Enriched approval data (Phase 1A)
  parentApprovalId    String?           // links resubmissions for request-changes cycle
  iteration           Int       @default(1) // defer/resubmit cycle count (max 3)
  urgency             String?           // LOW, MEDIUM, HIGH, CRITICAL
  expiresAt           DateTime?         // timeout/escalation deadline
  impactScores        Json?             // { schedule: 1-4, cost: 1-4, scope: 1-4, stakeholder: 1-4 }
  reasoningChain      String?   @db.Text // agent's explanation for the recommendation
  suggestedAlternatives Json?           // [{ description, impactScores, creditCost }]
  affectedItems       Json?             // [{ type: "task"|"risk"|"issue", id, title }]
}

// ─── Project Modules ───

model Phase {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  name        String
  order       Int
  status      String    @default("PENDING")
  artefacts   Json?
  approvalReq Boolean   @default(true)
  criteria    String?
  startDate   DateTime?
  endDate     DateTime?
}

model Task {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  title        String
  description  String?   @db.Text
  status       String    @default("TODO")
  priority     String?
  assigneeId   String?
  phaseId      String?
  parentId     String?
  startDate    DateTime?
  endDate      DateTime?
  progress     Int       @default(0)
  storyPoints  Int?
  dependencies Json?
  createdBy    String?   // "agent:<agentId>" or "user:<userId>"
  lastEditedBy String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Risk {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  description String?  @db.Text
  probability Int      @default(3)
  impact      Int      @default(3)
  score       Int?
  status      String   @default("OPEN")
  owner       String?
  mitigation  String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Issue {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?   @db.Text
  priority    String    @default("MEDIUM")
  status      String    @default("OPEN")
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChangeRequest {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  description String?  @db.Text
  impact      Json?
  status      String   @default("SUBMITTED")
  requestedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stakeholder {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id])
  name         String
  role         String?
  organisation String?
  power        Int     @default(50)
  interest     Int     @default(50)
  sentiment    String?
  email        String?
}

// ─── Billing ───

model CreditTransaction {
  id              String        @id @default(cuid())
  orgId           String
  org             Organisation  @relation(fields: [orgId], references: [id])
  amount          Int
  type            CreditTxnType
  description     String
  agentId         String?
  stripePaymentId String?
  createdAt       DateTime      @default(now())
}

model Invoice {
  id        String       @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  stripeId  String?      @unique
  amount    Float
  currency  String       @default("usd")
  status    String       @default("draft")
  pdfUrl    String?
  createdAt DateTime     @default(now())
}

model ApiKey {
  id        String       @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  name      String
  keyHash   String
  lastFour  String
  lastUsed  DateTime?
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime     @default(now())
}

// ─── Notifications ───

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String           @db.Text
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime         @default(now())
}

// ─── Audit ───

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  userId    String?
  action    String
  target    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())
}

// ─── Reports (Screen 23) ───

model Report {
  id          String       @id @default(cuid())
  title       String
  type        ReportType
  status      ReportStatus @default(DRAFT)
  format      String       @default("PDF")
  content     String?      @db.Text
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])
  agentId     String?
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  templateId  String?
  sections    Json?
  fileUrl     String?
  pageCount   Int?
  creditsUsed Int          @default(0)
  generatedAt DateTime     @default(now())
  publishedAt DateTime?
  editedAt    DateTime?
  editedBy    String?
  recipients  String[]
  versions    DocumentVersion[]
}

model DocumentVersion {
  id          String   @id @default(cuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id])
  version     Int
  content     String   @db.Text
  editedBy    String?
  comment     String?
  createdAt   DateTime @default(now())
}

model ReportSchedule {
  id             String   @id @default(cuid())
  name           String
  templateId     String
  projectId      String?
  orgId          String
  frequency      String   @default("WEEKLY")
  cronExpression String
  nextRunAt      DateTime
  recipients     String[]
  isActive       Boolean  @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime @default(now())
}

// ─── Meetings & Calendar ───

model Meeting {
  id            String              @id @default(cuid())
  title         String
  projectId     String?
  project       Project?            @relation(fields: [projectId], references: [id])
  orgId         String
  org           Organisation        @relation(fields: [orgId], references: [id])
  platform      String?             // zoom, teams, meet, other
  scheduledAt   DateTime?
  endedAt       DateTime?
  duration      Int?                // minutes
  status        MeetingStatus       @default(SCHEDULED)
  attendees     Json?               // [{name, email, role}]
  agentId       String?
  agent         Agent?              @relation(fields: [agentId], references: [id])
  // Transcript & AI processing
  rawTranscript String?             @db.Text
  summary       String?             @db.Text
  topics        Json?               // string[]
  sentiment     String?             // positive, neutral, concerned, negative
  speakers      Json?               // [{name, minutes, percentage}]
  confidence    Int?                // transcription confidence %
  // Extracted intelligence
  actionItems   MeetingActionItem[]
  decisions     Json?               // [{text, by, rationale, time}]
  risks         Json?               // [{title, description, severity}]
  processedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model MeetingActionItem {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  text       String
  assignee   String?
  deadline   String?
  status     String   @default("PENDING") // PENDING, IN_PROGRESS, DONE
  taskId     String?  // linked project task if promoted
  createdAt  DateTime @default(now())
}

model CalendarEvent {
  id           String       @id @default(cuid())
  orgId        String
  org          Organisation @relation(fields: [orgId], references: [id])
  projectId    String?
  project      Project?     @relation(fields: [projectId], references: [id])
  agentId      String?
  agent        Agent?       @relation(fields: [agentId], references: [id])
  title        String
  description  String?      @db.Text
  startTime    DateTime
  endTime      DateTime?
  location     String?
  meetingUrl   String?
  attendees    Json?        // [{name, email}]
  reminders    Json?        // pre/post meeting prompts
  // Agent intelligence
  preAgenda    String?      @db.Text  // AI-generated pre-meeting brief
  postUpdate   String?      @db.Text  // post-meeting update from user
  externalId   String?      // Google Calendar / external ID
  source       String       @default("MANUAL") // MANUAL, GOOGLE, OUTLOOK, EMAIL
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AgentEmail {
  id           String   @id @default(cuid())
  agentId      String   @unique
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  address      String   @unique  // e.g. maya@agents.projectoolbox.com
  forwardTo    String?            // optional human email for copies
  isActive     Boolean  @default(true)
  // Inbound log
  inboundCount Int      @default(0)
  lastReceived DateTime?
  createdAt    DateTime @default(now())
}

model AgentInboxMessage {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  from        String              // sender email
  subject     String
  preview     String   @db.Text   // first 500 chars of content
  contentHash String?             // for dedup
  type        String   @default("GENERAL") // GENERAL, MEETING_INVITE, MEETING_NOTES, STATUS_UPDATE
  status      String   @default("UNREAD")  // UNREAD, READ, PROCESSED, ARCHIVED
  // What the agent did with it
  processedAs String?             // "meeting", "calendar_event", "activity_log"
  linkedId    String?             // ID of the created meeting/event/etc
  metadata    Json?               // { attachmentCount, hasCalendar, etc }
  receivedAt  DateTime @default(now())

  @@index([orgId, agentId])
  @@index([orgId, status])
}

// ─── Daily Digest (Screen 24) ───

model DailyDigest {
  id          String   @id @default(cuid())
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  date        DateTime @db.Date
  summary     String   @db.Text
  highlights  Json?
  stats       Json?
  generatedAt DateTime @default(now())

  @@unique([orgId, date])
}

// ─── Agent Autonomy (job queue + artefacts) ───

model AgentJob {
  id           String    @id @default(cuid())
  agentId      String
  deploymentId String
  type         String    // autonomous_cycle | lifecycle_init | approval_resume | report_generate | user_edit_reconcile
  priority     Int       @default(5) // 1=highest
  status       String    @default("PENDING") // PENDING | CLAIMED | RUNNING | COMPLETED | FAILED
  payload      Json?
  result       Json?
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  scheduledFor DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  error        String?
  createdAt    DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([agentId, type])
}

model AgentArtefact {
  id        String   @id @default(cuid())
  agentId   String
  projectId String
  phaseId   String?
  name      String
  format    String   @default("markdown")
  content   String   @db.Text
  status    String   @default("DRAFT") // DRAFT | PENDING_REVIEW | APPROVED | REJECTED
  version   Int      @default(1)
  feedback  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, phaseId])
  @@index([projectId])
}

// ─── Agent Knowledge Base (Section 7.6) ───

model KnowledgeBaseItem {
  id           String   @id @default(cuid())
  agentId      String?           // null = workspace-level memory
  projectId    String?           // null = workspace-level
  orgId        String
  layer        String   @default("PROJECT")  // PROJECT | WORKSPACE | AGENT
  type         String   @default("TEXT")     // TEXT | FILE | URL | EMAIL | TRANSCRIPT | CHAT | DECISION
  title        String
  content      String   @db.Text
  sourceUrl    String?
  fileUrl      String?
  fileSize     Int?
  mimeType     String?
  trustLevel   String   @default("STANDARD") // HIGH_TRUST | STANDARD | REFERENCE_ONLY
  confidential Boolean  @default(false)
  tags         String[] @default([])
  metadata     Json?    // { sender, extractedFacts, sentiment, etc. }
  cachedUntil  DateTime?          // for research caching (7 days)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId, layer])
  @@index([agentId, type])
  @@index([projectId])
}

// ─── Project Decisions ───

model Decision {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  text      String
  decidedBy String?
  rationale String?  @db.Text
  meetingId String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ─── Enums ───

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Methodology {
  WATERFALL
  AGILE_SCRUM
  AGILE_KANBAN
  PRINCE2
  HYBRID
  SAFE
}

enum AgentStatus {
  IDLE
  ACTIVE
  PAUSED
  ERROR
  DECOMMISSIONED
}

enum DecisionType {
  TASK_ASSIGNMENT
  RISK_RESPONSE
  SCHEDULE_CHANGE
  RESOURCE_ALLOCATION
  ESCALATION
  BUDGET_CHANGE
  SCOPE_CHANGE
}

enum DecisionStatus {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
  AUTO_APPROVED
  CANCELLED
}

enum ApprovalType {
  PHASE_GATE
  CHANGE_REQUEST
  BUDGET
  RISK_RESPONSE
  SCOPE_CHANGE
  RESOURCE
  COMMUNICATION
  PROCUREMENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
  CANCELLED
}

enum CreditTxnType {
  PURCHASE
  SUBSCRIPTION_GRANT
  USAGE
  REFUND
  BONUS
}

enum NotificationType {
  AGENT_ALERT
  APPROVAL_REQUEST
  BILLING
  SYSTEM
  MILESTONE
  RISK_ESCALATION
}

enum ReportType {
  STATUS
  WEEKLY_DIGEST
  EVM
  RISK
  SPRINT_REVIEW
  EXECUTIVE
  STAKEHOLDER
  BUDGET
  PHASE_GATE
  CUSTOM
}

enum ReportStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  SCHEDULED
  FAILED
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
