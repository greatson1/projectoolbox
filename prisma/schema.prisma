generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth adapter) ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Orgs ───

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  emailVerified      DateTime?
  name               String?
  passwordHash       String?
  image              String?
  role               UserRole             @default(MEMBER)
  onboardingComplete Boolean              @default(false)
  notificationPrefs  Json?
  orgId              String?              // Active org (last selected)
  org                Organisation?        @relation(fields: [orgId], references: [id])
  organisations      UserOrganisation[]   // All orgs this user belongs to
  accounts           Account[]
  sessions           Session[]
  projects           ProjectMember[]
  approvals          Approval[]
  notifications      Notification[]
  decisions          Decision[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

// Multi-org membership — users can belong to multiple orgs with different roles
model UserOrganisation {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId    String
  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role     UserRole @default(MEMBER)
  joinedAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

// Invitation to join an org
model Invitation {
  id        String           @id @default(cuid())
  email     String
  orgId     String
  org       Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role      UserRole         @default(MEMBER)
  token     String           @unique
  status    InvitationStatus @default(PENDING)
  invitedBy String?
  expiresAt DateTime
  sentAt    DateTime         @default(now())
  acceptedAt DateTime?

  @@index([email])
  @@index([orgId])
}

// Magic link for external stakeholder review (no account needed)
model ReviewLink {
  id         String   @id @default(cuid())
  token      String   @unique
  approvalId String
  approval   Approval @relation(fields: [approvalId], references: [id])
  email      String?
  name       String?
  expiresAt  DateTime
  viewedAt   DateTime?
  actionedAt DateTime?
  action     String?  // APPROVED | REJECTED | CHANGES_REQUESTED
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
}

model Organisation {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  industry         String?
  companySize      String?
  website          String?
  timezone         String              @default("Europe/London")
  currency         String              @default("GBP") // GBP | USD | EUR — display + Stripe plan selection
  billingEmail     String?
  logoUrl          String?
  plan             PlanTier            @default(FREE)
  stripeCustomerId String?             @unique
  stripeSubId      String?
  creditBalance    Int                 @default(0)
  autoTopUp        Json?
  users            User[]
  memberships      UserOrganisation[]
  invitations      Invitation[]
  projects         Project[]
  agents           Agent[]
  invoices         Invoice[]
  creditTxns       CreditTransaction[]
  apiKeys          ApiKey[]
  webhooks         WebhookEndpoint[]
  auditLogs        AuditLog[]
  reports          Report[]
  dailyDigests     DailyDigest[]
  meetings         Meeting[]
  calendarEvents   CalendarEvent[]
  agentInbox       AgentInboxMessage[]
  integrations     Integration[]
  automationRules  AutomationRule[]
  mlInsights       MLInsight[]
  projectEmbeddings ProjectEmbedding[]
  sentimentHistory SentimentHistory[]
  globalHitlPolicy Json?               // org-level HITL governance overrides
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

// ─── Projects ───

model Project {
  id             String            @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus     @default(ACTIVE)
  methodology    Methodology       @default(WATERFALL)
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  tier           String?            // TASK | LIGHTWEIGHT | STANDARD | COMPLEX
  priority       String?
  category       String?
  orgId          String
  org            Organisation      @relation(fields: [orgId], references: [id])
  members        ProjectMember[]
  agents         AgentDeployment[]
  phases         Phase[]
  tasks          Task[]
  risks          Risk[]
  issues         Issue[]
  changeRequests ChangeRequest[]
  stakeholders   Stakeholder[]
  approvals      Approval[]
  reports        Report[]
  meetings       Meeting[]
  calendarEvents CalendarEvent[]
  decisions      Decision[]
  sprints        Sprint[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  // Archive metadata — soft-archive preserves the audit trail while marking
  // the project as read-only. archivedAt is the canonical "is archived" signal
  // in API checks (independent of status, so legacy rows still resolve).
  archivedAt     DateTime?
  archivedBy     String?
  archiveReason  String?
}

model ProjectMember {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  projectId  String
  project    Project @relation(fields: [projectId], references: [id])
  role       String  @default("MEMBER")
  hourlyRate Float?  // Cost rate for labour estimation
  skills     String[] @default([])

  @@unique([userId, projectId])
}

// ─── Agents ───

model Agent {
  id               String            @id @default(cuid())
  name             String
  codename         String
  title            String?           // user-defined job title e.g. "CRM Migration Lead"
  status           AgentStatus       @default(IDLE)
  autonomyLevel    Int               @default(2)
  personality      Json?
  gradient         String?
  avatarUrl        String?           // custom avatar image URL
  defaultGreeting  String?           // first-activation greeting
  domainTags       String[]          @default([]) // specialism tags e.g. ["PRINCE2", "Agile"]
  monthlyBudget    Int?              // credit cap per calendar month
  orgId            String
  org              Organisation      @relation(fields: [orgId], references: [id])
  deployments      AgentDeployment[]
  decisions        AgentDecision[]
  activities       AgentActivity[]
  chatMessages     ChatMessage[]
  meetings         Meeting[]
  calendarEvents   CalendarEvent[]
  agentEmail       AgentEmail?
  inboxMessages    AgentInboxMessage[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  decommissionedAt DateTime?
  // Archive metadata — soft-archive flag preserves the full audit trail while
  // stopping all autonomous activity. archivedAt is the canonical "is archived"
  // signal in API checks (independent of status, so legacy ARCHIVED rows
  // without status update still resolve correctly).
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
}

model AgentDeployment {
  id             String    @id @default(cuid())
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id])
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  isActive       Boolean   @default(true)
  config         Json?
  deployedAt     DateTime  @default(now())
  // Autonomous lifecycle state
  currentPhase   String?
  phaseStatus    String?   @default("active") // active | pending_approval | completed
  lastCycleAt    DateTime?
  nextCycleAt    DateTime?
  cycleInterval  Int       @default(10) // minutes between autonomous cycles
  // ── Cost guard: cycle pause + phase-aware scheduling ────────────────
  // The autonomous cycle (Sonnet + monitoring + alerts + scan) only adds
  // value during execution phases where there's real work to monitor.
  // Default true means new deployments start with the cycle DISABLED so
  // setup phases (research, clarification, gate review) don't burn Claude
  // credits on no-op cycles. The user enables it via the toggle on the
  // agent detail page when the project enters delivery.
  cyclePaused    Boolean   @default(true)
  healthStatus   String?   @default("GREEN") // GREEN | AMBER | RED
  autonomyConfig Json?     // { budgetApprovalThreshold, scopeChangeLimit, autoApprovePhases, requireApprovalFor }
  // HITL governance overrides (explicit columns for queryability)
  hitlPhaseGates      Boolean  @default(true)   // phase gates always require approval
  hitlBudgetChanges   Boolean  @default(true)   // budget changes always require approval
  hitlCommunications  Boolean  @default(false)  // external comms require approval
  escalationTimeout   Int      @default(24)     // hours before approval escalation
}

model AgentDecision {
  id          String         @id @default(cuid())
  agentId     String
  agent       Agent          @relation(fields: [agentId], references: [id])
  type        DecisionType
  description String
  reasoning   String         @db.Text
  confidence  Float
  status      DecisionStatus @default(PENDING)
  approvalId  String?        @unique
  approval    Approval?      @relation(fields: [approvalId], references: [id])
  createdAt   DateTime       @default(now())
}

model AgentActivity {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String
  summary   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id])
  conversationId String?
  role           String
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())
}

// ─── Approvals (HITL) ───

model Approval {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  requestedById String
  assignedToId  String?
  assignedTo    User?          @relation(fields: [assignedToId], references: [id])
  type          ApprovalType
  title         String
  description   String         @db.Text
  impact        Json?
  status        ApprovalStatus @default(PENDING)
  decision      AgentDecision?
  comment       String?        @db.Text
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  // Enriched approval data (Phase 1A)
  parentApprovalId    String?           // links resubmissions for request-changes cycle
  iteration           Int       @default(1) // defer/resubmit cycle count (max 3)
  urgency             String?           // LOW, MEDIUM, HIGH, CRITICAL
  expiresAt           DateTime?         // timeout/escalation deadline
  impactScores        Json?             // { schedule: 1-4, cost: 1-4, scope: 1-4, stakeholder: 1-4 }
  reasoningChain      String?   @db.Text // agent's explanation for the recommendation
  suggestedAlternatives Json?           // [{ description, impactScores, creditCost }]
  affectedItems       Json?             // [{ type: "task"|"risk"|"issue", id, title }]
  reviewLinks         ReviewLink[]
  // Sentiment — extracted from comment/description
  sentiment           String?           // positive, neutral, concerned, negative
  sentimentScore      Float?            // -1 to 1
  sentimentConfidence Float?            // 0 to 1
}

// ─── Project Modules ───

model Phase {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  name        String
  order       Int
  status      String    @default("PENDING")
  artefacts   Json?
  approvalReq Boolean   @default(true)
  criteria    String?
  startDate   DateTime?
  endDate     DateTime?
  // ── Pipeline-step audit fields ─────────────────────────────────────────
  // Authoritative timestamps for the canonical phase-step sequence so the
  // single phase-next-action resolver can decide "what must happen next"
  // without relying on inferring state from phaseStatus + KB tag heuristics
  // (which produced silent step-skip bugs).
  researchCompletedAt        DateTime?
  clarificationCompletedAt   DateTime?
  // Why clarification was skipped, if it was. Only two values allowed at
  // write-time: "no_questions_needed" (KB rich enough or LLM returned []),
  // "user_skipped_explicit" (user clicked Generate-without-asking). Any
  // other reason — API failure, parse error, etc — must NOT skip; the
  // resolver must require a retry instead.
  clarificationSkippedReason String?
  gateApprovedAt             DateTime?
}

model Sprint {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])
  name             String
  goal             String?   @db.Text
  startDate        DateTime
  endDate          DateTime
  status           String    @default("PLANNING") // PLANNING | ACTIVE | COMPLETED | CANCELLED
  committedPoints  Int       @default(0) // SP committed at sprint start (populated on COMPLETED)
  completedPoints  Int       @default(0) // SP delivered by end (populated on COMPLETED)
  tasks            Task[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Task {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  sprintId     String?
  sprint       Sprint?   @relation(fields: [sprintId], references: [id])
  title        String
  description  String?   @db.Text
  status       String    @default("TODO")
  priority     String?
  type         String    @default("task")  // task | story | bug | spike
  epic         String?
  labels       Json?                        // string[]
  blocked      Boolean   @default(false)
  assigneeId   String?
  assigneeName String?
  phaseId      String?
  parentId     String?
  startDate    DateTime?
  endDate      DateTime?
  progress     Int       @default(0)
  storyPoints     Int?
  estimatedHours  Float?    // used by cost-estimator and EVM
  actualHours     Float?    // actual tracked hours for EVM AC calculation
  isCriticalPath  Boolean   @default(false) // set by critical-path engine
  dependencies    Json?
  createdBy       String?   // "agent:<agentId>" or "user:<userId>"
  lastEditedBy    String?
  // ── Source artefact linkage (artefact action extraction) ─────────────
  // Set when this Task was created by parsing the "Next Actions" table of
  // an approved artefact. sourceRowKey is a stable hash of the parsed
  // (Action + Owner) so the extractor can update existing tasks on
  // re-extraction (e.g. after the artefact is regenerated) instead of
  // creating duplicates. Both nullable for tasks created any other way.
  sourceArtefactId String?
  sourceRowKey     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sourceArtefactId])
}

model Risk {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  title          String
  description    String?  @db.Text
  probability    Int      @default(3)
  impact         Int      @default(3)
  score          Int?
  status         String   @default("OPEN")
  owner          String?
  mitigation     String?  @db.Text
  category       String?
  // Response action log — array of { id, strategy, action, owner, dueDate, status, notes, createdAt }
  responseLog    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Issue {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?   @db.Text
  priority    String    @default("MEDIUM")
  status      String    @default("OPEN")
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChangeRequest {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  description String?  @db.Text
  impact      Json?
  status      String   @default("SUBMITTED")
  requestedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stakeholder {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id])
  name         String
  role         String?
  organisation String?
  power        Int     @default(50)
  interest     Int     @default(50)
  sentiment    String?
  sentimentScore Float?       // -1 to 1, refreshed automatically from activity
  sentimentUpdatedAt DateTime?
  email        String?
}

// ─── Billing ───

model CreditTransaction {
  id              String        @id @default(cuid())
  orgId           String
  org             Organisation  @relation(fields: [orgId], references: [id])
  amount          Int
  type            CreditTxnType
  description     String
  agentId         String?
  stripePaymentId String?
  createdAt       DateTime      @default(now())
}

model Invoice {
  id        String       @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  stripeId  String?      @unique
  amount    Float
  currency  String       @default("usd")
  status    String       @default("draft")
  pdfUrl    String?
  createdAt DateTime     @default(now())
}

model ApiKey {
  id        String       @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  name      String
  keyHash   String
  lastFour  String
  lastUsed  DateTime?
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime     @default(now())
}

model WebhookEndpoint {
  id        String       @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  url       String
  events    String[]
  secret    String
  isActive  Boolean      @default(true)
  lastFired DateTime?
  failCount Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([orgId])
}

// ─── Machine Learning Insights ───

model MLInsight {
  id         String   @id @default(cuid())
  orgId      String
  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  kind       String   // approval_likelihood, impact_calibration, story_point_calibration, risk_materialisation
  subjectId  String?
  subjectType String?
  score      Float
  confidence Float    @default(0.5)
  data       Json     @default("{}")
  trainedAt  DateTime @default(now())
  expiresAt  DateTime?

  @@index([orgId, kind])
  @@index([orgId, kind, subjectId])
}

model ProjectEmbedding {
  id         String   @id @default(cuid())
  orgId      String
  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId  String   @unique
  embedding  Json
  sourceText String   @db.Text
  model      String   @default("text-embedding-3-small")
  dims       Int      @default(1536)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId])
}

// ─── Integrations ───

model Integration {
  id           String   @id @default(cuid())
  orgId        String
  org          Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type         String   // slack, teams, jira, asana, monday, google_calendar, discord, email, webhook, n8n
  name         String   // User-friendly label e.g. "Slack — #project-alpha"
  config       Json     @default("{}") // channel IDs, webhook URLs, API keys (encrypted at rest)
  status       String   @default("disconnected") // connected, disconnected, error
  lastSyncAt   DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  automationRules AutomationRule[]

  @@index([orgId])
  @@index([orgId, type])
}

model AutomationRule {
  id            String   @id @default(cuid())
  orgId         String
  org           Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String   // "Slack alert on high risk"
  trigger       String   // risk_high, task_overdue, phase_gate_approved, budget_threshold, sprint_completed, artefact_generated, agent_needs_input, approval_pending
  action        String   // send_slack, send_teams, send_email, create_jira_ticket, create_calendar_event, call_webhook, send_discord
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  config        Json     @default("{}") // channel, recipients, template, conditions
  projectId     String?  // null = all projects
  isActive      Boolean  @default(true)
  lastFiredAt   DateTime?
  fireCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, trigger])
}

// ─── Notifications ───

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String           @db.Text
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime         @default(now())
}

// ─── Audit ───

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id])
  userId    String?
  action    String
  target    String
  details      Json?
  ip           String?
  // Spec additions for agent audit trail
  projectId    String?
  agentId      String?
  cycleId      String?
  entityType   String?    // task | risk | artefact | approval | cost_entry
  entityId     String?
  rationale    String?    @db.Text
  dataSnapshot Json?
  createdAt    DateTime   @default(now())

  @@index([projectId])
}

// ─── Reports (Screen 23) ───

model Report {
  id          String       @id @default(cuid())
  title       String
  type        ReportType
  status      ReportStatus @default(DRAFT)
  format      String       @default("PDF")
  content     String?      @db.Text
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])
  agentId     String?
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  templateId  String?
  sections    Json?
  fileUrl     String?
  pageCount   Int?
  creditsUsed Int          @default(0)
  generatedAt DateTime     @default(now())
  publishedAt DateTime?
  editedAt    DateTime?
  editedBy    String?
  recipients  String[]
  versions    DocumentVersion[]
}

model DocumentVersion {
  id          String   @id @default(cuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id])
  version     Int
  content     String   @db.Text
  editedBy    String?
  comment     String?
  createdAt   DateTime @default(now())
}

model ReportSchedule {
  id             String   @id @default(cuid())
  name           String
  templateId     String
  projectId      String?
  orgId          String
  frequency      String   @default("WEEKLY")
  cronExpression String
  nextRunAt      DateTime
  recipients     String[]
  isActive       Boolean  @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime @default(now())
}

// ─── Meetings & Calendar ───

model Meeting {
  id            String              @id @default(cuid())
  title         String
  projectId     String?
  project       Project?            @relation(fields: [projectId], references: [id])
  orgId         String
  org           Organisation        @relation(fields: [orgId], references: [id])
  platform      String?             // zoom, teams, meet, other
  scheduledAt   DateTime?
  endedAt       DateTime?
  duration      Int?                // minutes
  status        MeetingStatus       @default(SCHEDULED)
  attendees     Json?               // [{name, email, role}]
  agentId       String?
  agent         Agent?              @relation(fields: [agentId], references: [id])
  // Transcript & AI processing
  rawTranscript String?             @db.Text
  summary       String?             @db.Text
  topics        Json?               // string[]
  sentiment     String?             // positive, neutral, concerned, negative
  speakers      Json?               // [{name, minutes, percentage}]
  confidence    Int?                // transcription confidence %
  // Bot integration (Recall.ai or custom Playwright bot)
  botProvider     String?  @default("recall")  // "recall" | "custom"
  recallBotId     String?           // bot ID (Recall or custom bot service)
  recallBotStatus String?           // idle | joining | waiting | recording | done | failed
  calendarEventId String?           // optional link to CalendarEvent
  meetingUrl      String?           // the video call URL the bot joined
  // Extracted intelligence
  actionItems   MeetingActionItem[]
  decisions     Json?               // [{text, by, rationale, time}]
  risks         Json?               // [{title, description, severity}]
  processedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model MeetingActionItem {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  text       String
  assignee   String?
  deadline   String?
  status     String   @default("PENDING") // PENDING, IN_PROGRESS, DONE
  taskId     String?  // linked project task if promoted
  createdAt  DateTime @default(now())
}

model CalendarEvent {
  id           String       @id @default(cuid())
  orgId        String
  org          Organisation @relation(fields: [orgId], references: [id])
  projectId    String?
  project      Project?     @relation(fields: [projectId], references: [id])
  agentId      String?
  agent        Agent?       @relation(fields: [agentId], references: [id])
  title        String
  description  String?      @db.Text
  startTime    DateTime
  endTime      DateTime?
  location     String?
  meetingUrl   String?
  attendees    Json?        // [{name, email}]
  reminders    Json?        // pre/post meeting prompts
  // Agent intelligence
  preAgenda    String?      @db.Text  // AI-generated pre-meeting brief
  postUpdate   String?      @db.Text  // post-meeting update from user
  externalId   String?      // Google Calendar / external ID
  source       String       @default("MANUAL") // MANUAL, GOOGLE, OUTLOOK, EMAIL
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AgentEmail {
  id           String   @id @default(cuid())
  agentId      String   @unique
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  address      String   @unique  // e.g. maya@agents.projectoolbox.com
  forwardTo    String?            // optional human email for copies
  isActive     Boolean  @default(true)
  // Inbound log
  inboundCount Int      @default(0)
  lastReceived DateTime?
  createdAt    DateTime @default(now())
}

model AgentInboxMessage {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  from        String              // sender email
  subject     String
  preview     String   @db.Text   // first 500 chars of content
  contentHash String?             // for dedup
  type        String   @default("GENERAL") // GENERAL, MEETING_INVITE, MEETING_NOTES, STATUS_UPDATE
  status      String   @default("UNREAD")  // UNREAD, READ, PROCESSED, ARCHIVED
  // What the agent did with it
  processedAs String?             // "meeting", "calendar_event", "activity_log"
  linkedId    String?             // ID of the created meeting/event/etc
  metadata    Json?               // { attachmentCount, hasCalendar, etc }
  // Sentiment
  sentiment   String?             // positive, neutral, concerned, negative
  sentimentScore Float?
  receivedAt  DateTime @default(now())

  @@index([orgId, agentId])
  @@index([orgId, status])
}

// ─── Daily Digest (Screen 24) ───

model DailyDigest {
  id          String   @id @default(cuid())
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  date        DateTime @db.Date
  summary     String   @db.Text
  highlights  Json?
  stats       Json?
  generatedAt DateTime @default(now())

  @@unique([orgId, date])
}

// ─── Agent Autonomy (job queue + artefacts) ───

model AgentJob {
  id           String    @id @default(cuid())
  agentId      String
  deploymentId String
  type         String    // autonomous_cycle | lifecycle_init | approval_resume | report_generate | user_edit_reconcile
  priority     Int       @default(5) // 1=highest
  status       String    @default("PENDING") // PENDING | CLAIMED | RUNNING | COMPLETED | FAILED
  payload      Json?
  result       Json?
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  scheduledFor DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  error        String?
  createdAt    DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([agentId, type])
}

model AgentArtefact {
  id        String   @id @default(cuid())
  agentId   String
  projectId String
  phaseId   String?
  name      String
  format    String   @default("markdown")
  content   String   @db.Text
  status    String   @default("DRAFT") // DRAFT | PENDING_REVIEW | APPROVED | REJECTED
  version   Int      @default(1)
  feedback  String?  @db.Text
  metadata  Json?
  // ── Cross-artefact linkage ────────────────────────────────────────────
  // Names (not IDs — the canonical reference in DEPENDENCY_MAP and
  // methodology definitions is by artefact name) of artefacts this one
  // depends on. Maintained by the dependency-tracker on approval.
  // Stored as Json so we don't need a separate join table for what is
  // a small-cardinality reference list.
  linkedArtefactNames Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, phaseId])
  @@index([projectId])
}

// ─── Cost Tracking ───

model CostEntry {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  entryType   String   @default("ESTIMATE")  // ESTIMATE | ACTUAL | FORECAST | COMMITMENT
  category    String   @default("LABOUR")    // LABOUR | MATERIALS | SERVICES | TRAVEL | CONTINGENCY | OTHER
  amount      Float
  currency    String   @default("GBP")
  description String?
  vendorName  String?              // Supplier/vendor for materials/services
  poNumber    String?              // Purchase order reference
  invoiceRef  String?              // Invoice reference for actuals
  unitQty     Float?               // Quantity (e.g. 10 licenses, 5 days)
  unitRate    Float?               // Rate per unit (e.g. £500/license, £800/day)
  recordedAt  DateTime @default(now())
  createdBy   String?              // agent:<id> or user:<id>

  @@index([projectId])
  @@index([projectId, category])
}

// ─── Benefits Realisation ───

model Benefit {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  description    String?
  category       String   @default("Strategic") // Strategic | Financial | Operational
  status         String   @default("NOT_STARTED") // NOT_STARTED | ON_TRACK | AT_RISK | REALISED
  targetValue    Float    @default(0)
  realisedValue  Float    @default(0)
  currency       String   @default("GBP")
  owner          String?              // Role title or person name
  targetDate     DateTime?
  measures       String?              // How benefit is measured (KPI description)
  createdBy      String?              // agent:<id> or user:<id>
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

// ─── Metrics Snapshots ───

model MetricsSnapshot {
  id                   String    @id @default(cuid())
  projectId            String
  cycleId              String?
  pv                   Float?
  ev                   Float?
  ac                   Float?
  spi                  Float?
  cpi                  Float?
  eac                  Float?
  ragStatus            String?
  tasksTotal           Int?
  tasksComplete        Int?
  tasksOverdue         Int?
  risksOpen            Int?
  risksCritical        Int?
  forecastEndDate      DateTime?
  onBudgetProbability  Float?
  createdAt            DateTime  @default(now())

  @@index([projectId, createdAt])
}

// ─── Communications Log ───

model CommsLog {
  id          String   @id @default(cuid())
  projectId   String
  agentId     String?
  channel     String   @default("EMAIL")
  recipient   String
  subject     String?
  content     String?  @db.Text
  status      String   @default("SENT")
  sentAt      DateTime @default(now())
  // Sentiment
  sentiment   String?  // positive, neutral, concerned, negative
  sentimentScore Float?
  // For inbound/reply sentiment
  direction   String?  // OUTBOUND, INBOUND

  @@index([projectId])
}

// ─── Sentiment History (time series for trend analysis) ───

model SentimentHistory {
  id             String   @id @default(cuid())
  orgId          String
  org            Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subjectType    String   // stakeholder, project, org, user
  subjectId      String
  sentiment      String   // positive, neutral, concerned, negative
  score          Float    // -1 to 1
  source         String   // approval, chat, email, meeting, manual
  sourceRef      String?  // ID of the triggering record
  createdAt      DateTime @default(now())

  @@index([orgId, subjectType, subjectId, createdAt])
  @@index([orgId, createdAt])
}

// ─── Agent Knowledge Base (Section 7.6) ───

model KnowledgeBaseItem {
  id           String   @id @default(cuid())
  agentId      String?           // null = workspace-level memory
  projectId    String?           // null = workspace-level
  orgId        String
  layer        String   @default("PROJECT")  // PROJECT | WORKSPACE | AGENT
  type         String   @default("TEXT")     // TEXT | FILE | URL | EMAIL | TRANSCRIPT | CHAT | DECISION
  title        String
  content      String   @db.Text
  sourceUrl    String?
  fileUrl      String?
  fileSize     Int?
  mimeType     String?
  trustLevel   String   @default("STANDARD") // HIGH_TRUST | STANDARD | REFERENCE_ONLY
  confidential Boolean  @default(false)
  tags         String[] @default([])
  metadata     Json?    // { sender, extractedFacts, sentiment, etc. }
  cachedUntil  DateTime?          // for research caching (7 days)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId, layer])
  @@index([agentId, type])
  @@index([projectId])
}

// ─── Project Decisions ───

model Decision {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  text      String
  decidedBy String?
  rationale String?  @db.Text
  meetingId String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

